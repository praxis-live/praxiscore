@ /data root:data {
  @ ./functions core:custom {
    .meta [map graph.x 105 graph.y 93]
    .code {
    record Point(int x, int y) {

    }

    @Inject Async.MapQueue<Point, Async<Point>> transformQueue;

    @Override
    public void init() {
        transformQueue.onDone(
                (in, out) -> {
                    out.complete(swapPoint(in));
                },
                (err, out) -> {
                    out.fail(err);
                });
    }

    @FN
    String uppercase(String input) {
        return input.toUpperCase(Locale.ROOT);
    }

    @FN
    Async<String> uppercaseAsync(String input) {
        return async(input, s -> s.toUpperCase(Locale.ROOT));
    }

    @FN
    void noOp() {
    }

    @FN
    String error() {
        throw new UnsupportedOperationException();
    }

    @FN.Watch(mime = "text/plain")
    Async<String> watchRepeat(PMap query) {
        return async(query, q -> {
            int count = q.getInt("count", 0);
            String text = q.getString("text", "???");
            return text.repeat(count);
        });
    }

    @FN
    Point makePoint(@Type.Integer(min = 0, max = 10) int x,
            @Type.Integer(min = 0, max = 10) int y) {
        return new Point(x, y);
    }

    @FN
    Async<Point> makeAsyncPoint(int x, int y) {
        return async("", s -> new Point(x, y));
    }

    @FN
    Point swapPoint(Point point) {
        return new Point(point.y(), point.x());
    }

    @FN
    Async<Point> asyncSwapPoint(int x, int y) {
        Async<Point> reply = new Async<>();
        transformQueue.add(makeAsyncPoint(x, y), reply);
        return reply;
    }

    @FN
    Async<Point> asyncSwapPointError(int x, int y) {
        Async<Point> reply = new Async<>();
        transformQueue.add(async("", s -> {
            throw new UnsupportedOperationException();
        }), reply);
        return reply;
    }

}
  }
}
