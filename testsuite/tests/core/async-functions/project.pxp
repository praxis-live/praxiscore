hub {
  enable-fileserver false
  proxies {
    data1 {
      host localhost
      port auto
      id-pattern data1
      type-pattern *
      exec {
        command default
        java-options {
          -Dpraxis.test.child=true
        }
      }
    }
    data2 {
      host localhost
      port auto
      id-pattern data2
      type-pattern *
      exec {
        command default
        java-options {
          -Dpraxis.test.child=true
        }
      }
    }
  }
}
compiler {
  release 21
}
libraries {}

# <<<BUILD>>>
include [file "data.pxr"]
include [file "tests.pxr"]

# <<<RUN>>>
/data.start
/tests.start
